{
  "name": "admin-console",
  "type": "module",
  "category": "operations",
  "title": "Admin Console",
  "description": "Super-admin shell for users, workspaces, metrics, and operational controls.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "audit-log"
  ],
  "env": [],
  "files": [
    {
      "path": "apps/web/src/lib/admin-console.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "admin-console",
      "nextjs"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
