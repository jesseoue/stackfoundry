{
  "name": "github-integration",
  "type": "integration",
  "category": "integrations",
  "title": "GitHub Integration",
  "description": "GitHub App Octokit client, webhook route starter, and repository action example.",
  "dependencies": [
    "octokit"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "webhook-inbox"
  ],
  "env": [
    "GITHUB_APP_ID",
    "GITHUB_PRIVATE_KEY",
    "GITHUB_WEBHOOK_SECRET"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/github/app.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/api/webhooks/github/route.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/vendors/github/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "github-integration",
      "github",
      "nextjs"
    ],
    "rules": [
      "verify-webhook-signatures",
      "store-private-key-safely",
      "dedupe-deliveries"
    ]
  }
}
