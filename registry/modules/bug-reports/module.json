      "bugReports"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "bug-reports",
      "nextjs",
      "drizzle"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "safe-defaults"
    ]
  }
