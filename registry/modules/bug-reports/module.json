{
  "name": "bug-reports",
  "type": "module",
  "category": "support",
  "title": "Bug Reports",
  "description": "Bug report intake, severity, reproduction steps, and triage workflow.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "support-console"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/bug-reports.ts",
