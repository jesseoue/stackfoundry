{
  "name": "cloudflare-workflows",
  "type": "integration",
  "category": "workflow",
  "title": "Cloudflare Workflows",
  "description": "Cloudflare Workflows durable step starter for Workers-native orchestration.",
  "dependencies": [],
  "devDependencies": [
    "wrangler"
  ],
  "registryDependencies": [
    "cloudflare-workers"
  ],
  "env": [],
  "files": [
    {
      "path": "cloudflare/workflows/onboarding.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/cloudflare/workflows/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "cloudflare-workflows",
      "cloudflare",
      "nextjs"
    ],
    "rules": [
      "keep-steps-idempotent",
      "log-workflow-progress",
      "test-with-wrangler"
    ]
  }
}
