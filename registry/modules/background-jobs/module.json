{
  "name": "background-jobs",
  "type": "module",
  "category": "operations",
  "title": "Background Jobs",
  "description": "Job table, queue abstraction, retry/cancel UI, and worker handoff patterns.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/background-jobs.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/background-jobs.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/jobs/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "backgroundJobs"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "background-jobs"
    ],
    "rules": [
      "idempotent-handlers",
      "bounded-retries",
      "record-failures"
    ]
  }
}
