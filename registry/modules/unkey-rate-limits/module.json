{
  "name": "unkey-rate-limits",
  "type": "integration",
  "category": "operations",
  "title": "Unkey Rate Limits",
  "description": "Unkey rate limit namespace helper and protected route example.",
  "dependencies": [
    "@unkey/ratelimit"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "rate-limits"
  ],
  "env": [
    "UNKEY_ROOT_KEY"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/unkey/ratelimit.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/api/vendor/unkey/ratelimit/route.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/vendors/unkey-rate-limits/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "unkey-rate-limits",
      "unkey"
    ],
    "rules": [
      "namespace-limits",
      "return-standard-limit-headers",
      "avoid-client-side-root-key"
    ]
  }
}
