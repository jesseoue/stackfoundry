{
  "name": "invites",
  "type": "module",
  "category": "auth",
  "title": "Invites",
  "description": "Email invitations, pending invitation state, role assignment, and resend/cancel flows.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/invites.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/invites.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/settings/workspace/invites/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "workspaceInvites"
    ],
    "migrationRecommended": true
  },
  "status": "ready",
  "maintenance": {
    "skills": [
      "invites",
      "nextjs",
      "drizzle"
    ],
    "rules": [
      "hash-invite-tokens",
      "expire-pending-invites",
      "audit-membership-changes"
    ]
  }
}
