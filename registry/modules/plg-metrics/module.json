{
  "name": "plg-metrics",
  "type": "module",
  "category": "analytics",
  "title": "PLG Metrics",
  "description": "Product-led growth event schema, metric helpers, and activation metrics dashboard starter.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/plg-metrics.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/stackfoundry/plg-metrics.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/analytics/plg/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "ready",
  "maintenance": {
    "skills": [
      "plg-metrics",
      "drizzle",
      "nextjs"
    ],
    "rules": [
      "define-event-taxonomy",
      "keep-metrics-tenant-scoped",
      "separate-ingestion-from-analysis"
    ]
  }
}
