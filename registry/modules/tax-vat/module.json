{
  "name": "tax-vat",
  "type": "module",
  "category": "billing",
  "title": "Tax and VAT",
  "description": "Tax/VAT collection status, business identifiers, and tax provider adapter boundary.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "billing-core"
  ],
  "env": [],
