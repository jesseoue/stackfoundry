{
  "name": "notification-center",
  "type": "module",
  "category": "operations",
  "title": "Notification Center",
  "description": "In-app notification inbox with read state and preference-aware display.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "notifications"
  ],
  "env": [],
  "files": [
    {
      "path": "apps/web/src/lib/notification-center.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/notifications/center/page.tsx",
      "type": "registry:page"
    }
  ],
  "agents": {
    "skills": [
      "notification-center"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
