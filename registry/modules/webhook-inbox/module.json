{
  "name": "webhook-inbox",
  "type": "module",
  "category": "developer-platform",
  "title": "Webhook Inbox",
  "description": "Inbound webhook capture, signature metadata, and replay workflow.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/webhook-inbox.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/webhook-inbox.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/webhooks/inbox/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "webhookInbox"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "webhook-inbox"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
