{
  "name": "feature-flags",
  "type": "module",
  "category": "growth",
  "title": "Feature Flags",
  "description": "Flag table, evaluation helper, admin UI, and per-org targeting.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
