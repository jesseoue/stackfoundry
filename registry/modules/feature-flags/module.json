      "featureFlags"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "feature-flags"
    ],
    "rules": [
      "stable-evaluation",
      "default-closed",
      "document-rollouts"
    ]
  }
