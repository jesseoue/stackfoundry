{
  "name": "plan-gating",
  "type": "module",
  "category": "billing",
  "title": "Plan Gating",
  "description": "Server-side plan checks and upgrade prompt surfaces.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "entitlements"
  ],
  "env": [],
  "files": [
    {
      "path": "apps/web/src/lib/plan-gating.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/billing/plan-gating/page.tsx",
      "type": "registry:page"
    }
  ],
  "agents": {
    "skills": [
      "plan-gating"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
