{
  "name": "data-retention",
  "type": "module",
  "category": "compliance",
  "title": "Data Retention",
  "description": "Retention policies, deletion windows, and compliance review UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/data-retention.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/data-retention.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/data/retention/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "dataRetention"
    ],
    "migrationRecommended": true
  },
  "status": "ready",
  "maintenance": {
    "skills": [
      "data-retention",
      "nextjs",
      "drizzle"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
