{
  "name": "usage-metering",
  "type": "module",
  "category": "billing",
  "title": "Usage Metering",
  "description": "Usage event capture, aggregation helpers, and billing-ready usage UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/usage-metering.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/usage-metering.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/usage/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "usageMetering"
    ],
    "migrationRecommended": true
  },
  "agents": {
    "skills": [
      "usage-metering"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
