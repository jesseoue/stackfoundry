{
  "name": "auth-better-auth",
  "type": "integration",
  "category": "auth",
  "title": "Better Auth",
  "description": "Better Auth server config, Next.js route handler, and typed client starter.",
  "dependencies": [
    "better-auth"
  ],
  "devDependencies": [],
  "registryDependencies": [],
  "env": [
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/auth.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/auth-client.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/api/auth/[...all]/route.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/auth/better-auth/page.tsx",
      "type": "registry:page"
    }
  ],
  "agents": {
    "skills": [
      "auth-better-auth"
    ],
    "rules": [
      "run-auth-migrations",
      "protect-secret",
      "document-enabled-plugins"
    ]
  },
  "status": "experimental"
}
