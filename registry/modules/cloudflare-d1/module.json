{
  "name": "cloudflare-d1",
  "type": "integration",
  "category": "database",
  "title": "Cloudflare D1",
  "description": "D1 binding usage, SQLite schema starter, and Wrangler database notes.",
  "dependencies": [],
  "devDependencies": [
    "wrangler"
  ],
  "registryDependencies": [
    "cloudflare-workers"
  ],
  "env": [],
  "files": [
    {
      "path": "cloudflare/d1/schema.sql",
      "type": "registry:file"
    },
    {
      "path": "cloudflare/d1/queries.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/cloudflare/d1/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "ready",
  "maintenance": {
    "skills": [
      "cloudflare-d1",
      "cloudflare",
      "nextjs"
    ],
    "rules": [
      "commit-sql-migrations",
      "bind-d1-explicitly",
      "test-with-wrangler"
    ]
  }
}
