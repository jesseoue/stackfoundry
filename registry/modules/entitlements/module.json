{
  "name": "entitlements",
  "type": "module",
  "category": "billing",
  "title": "Entitlements",
  "description": "Feature entitlement definitions, checks, and admin review UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/entitlements.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/entitlements.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/billing/entitlements/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "entitlements"
    ],
    "migrationRecommended": true
  },
  "agents": {
    "skills": [
      "entitlements"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
