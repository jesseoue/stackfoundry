{
  "name": "account-settings",
  "type": "page",
  "category": "auth",
  "title": "Account Settings",
  "description": "Profile, security, sessions, and notification preference pages.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [],
  "env": [],
  "files": [
    {
      "path": "apps/web/src/app/(console)/settings/account/page.tsx",
      "type": "registry:page"
    },
    {
      "path": "apps/web/src/lib/account-settings.ts",
      "type": "registry:file"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "account-settings",
      "nextjs"
    ],
    "rules": [
      "separate-user-and-workspace-settings",
      "protect-security-actions",
      "confirm-destructive-actions"
    ]
  }
}
