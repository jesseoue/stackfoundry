{
  "name": "webhook-delivery",
  "type": "module",
  "category": "developer-platform",
  "title": "Webhook Delivery",
  "description": "Outbound webhook endpoints, signing helpers, retries, and delivery logs.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/webhook-delivery.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/webhook-delivery.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/developers/webhooks/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "webhookDelivery"
    ],
    "migrationRecommended": true
  },
  "agents": {
    "skills": [
      "webhook-delivery"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
