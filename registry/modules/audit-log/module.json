{
  "name": "audit-log",
  "type": "module",
  "category": "operations",
  "title": "Audit Log",
  "description": "Append-only activity table, event helpers, and admin timeline UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/audit-log.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/audit-log.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/audit-log/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "auditLogEvents"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "audit-log"
    ],
    "rules": [
      "append-only-events",
      "namespace-actions",
      "avoid-sensitive-metadata"
    ]
  }
}
