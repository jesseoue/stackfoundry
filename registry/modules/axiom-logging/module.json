{
  "name": "axiom-logging",
  "type": "integration",
  "category": "observability",
  "title": "Axiom Logging",
  "description": "Axiom structured event logger and server route for deployment smoke checks.",
  "dependencies": [
    "@axiomhq/js"
  ],
  "devDependencies": [],
  "registryDependencies": [],
  "env": [
    "AXIOM_TOKEN",
    "AXIOM_DATASET"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/axiom/logger.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/api/providers/axiom/log/route.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/providers/axiom/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "ready",
  "maintenance": {
    "skills": [
      "axiom-logging",
      "axiom",
      "nextjs"
    ],
    "rules": [
      "use-structured-events",
      "avoid-logging-secrets",
      "sample-noisy-events"
    ]
  }
}
