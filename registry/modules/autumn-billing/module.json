{
  "name": "autumn-billing",
  "type": "integration",
  "category": "billing",
  "title": "Autumn Billing",
  "description": "Autumn billing adapter for plan attach, checkout redirects, usage billing, and plan changes.",
  "dependencies": [
    "autumn-js"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "billing-core",
    "usage-metering"
  ],
  "env": [
    "AUTUMN_SECRET_KEY"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/autumn/billing.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/providers/autumn-billing/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "autumn-billing",
      "autumn",
      "nextjs"
    ],
    "rules": [
      "keep-provider-boundary",
      "map-provider-state",
      "verify-checkout-redirects",
      "never-trust-client-plan-ids"
    ]
  }
}
