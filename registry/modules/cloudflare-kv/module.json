{
  "name": "cloudflare-kv",
  "type": "integration",
  "category": "storage",
  "title": "Cloudflare KV",
  "description": "KV binding adapter for low-write configuration, flags, and cached metadata.",
  "dependencies": [],
  "devDependencies": [
    "wrangler"
  ],
  "registryDependencies": [
    "feature-flags"
  ],
  "env": [],
  "files": [
    {
      "path": "cloudflare/kv/config.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/cloudflare/kv/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "cloudflare-kv",
      "cloudflare",
      "nextjs"
    ],
    "rules": [
      "avoid-high-write-counters",
      "namespace-keys",
      "document-eventual-consistency"
    ]
  }
}
