{
	"name": "drizzle-postgres",
	"type": "module",
	"category": "database",
	"title": "Drizzle Postgres",
	"description": "Postgres + Drizzle package, schema barrel, migrations, and server-only DB access.",
	"dependencies": ["drizzle-orm", "postgres"],
	"devDependencies": ["drizzle-kit", "dotenv"],
	"registryDependencies": [],
	"env": ["DATABASE_URL"],
	"files": [
		{
			"path": "packages/db/package.json",
			"type": "registry:file"
		},
		{
			"path": "packages/db/src/client.ts",
			"type": "registry:file"
		},
		{
			"path": "packages/db/src/index.ts",
			"type": "registry:file"
		},
		{
			"path": "packages/db/src/schema/index.ts",
			"type": "registry:file"
		},
		{
			"path": "apps/web/src/lib/db.ts",
			"type": "registry:file"
		},
		{
			"path": "drizzle.config.ts",
			"type": "registry:file"
		}
	],
	"drizzle": {
		"schemaExports": [],
		"migrationRecommended": true
	},
	"agents": {
		"skills": ["drizzle-postgres"],
		"rules": ["server-only", "schema-barrel", "commit-migrations"]
	},
	"status": "experimental"
}
