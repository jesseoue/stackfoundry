{
  "name": "incident-management",
  "type": "module",
  "category": "operations",
  "title": "Incident Management",
  "description": "Incident records, severity, status updates, and internal coordination UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/incident-management.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/incident-management.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/incidents/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "incidentManagement"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "incident-management"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
