{
  "name": "docs-fumadocs",
  "type": "module",
  "category": "docs",
  "title": "Fumadocs Docs",
  "description": "In-app Next.js documentation starter with Fumadocs setup and deployment guidance.",
  "dependencies": [
    "fumadocs-core",
    "fumadocs-ui"
  ],
  "devDependencies": [
    "fumadocs-mdx"
  ],
  "registryDependencies": [
    "seo"
  ],
  "env": [],
  "files": [
    {
      "path": "apps/web/src/lib/docs/fumadocs.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(marketing)/docs/page.tsx",
      "type": "registry:page"
    },
    {
      "path": "docs/fumadocs-deployment.md",
      "type": "registry:file"
    }
  ],
  "status": "ready",
  "maintenance": {
    "skills": [
      "docs-fumadocs",
      "fumadocs",
      "docs-hosting",
      "nextjs"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
