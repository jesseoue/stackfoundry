{
  "name": "file-uploads",
  "type": "module",
  "category": "storage",
  "title": "File Uploads",
  "description": "File metadata, upload policy helpers, and upload management UI.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/file-uploads.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/file-uploads.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/files/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "fileUploads"
    ],
    "migrationRecommended": true
  },
  "status": "experimental",
  "maintenance": {
    "skills": [
      "file-uploads"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
