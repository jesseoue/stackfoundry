{
  "name": "neon-postgres",
  "type": "integration",
  "category": "database",
  "title": "Neon Postgres",
  "description": "Neon serverless Postgres client, Drizzle-compatible env wiring, and branching notes.",
  "dependencies": [
    "@neondatabase/serverless"
  ],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [
    "DATABASE_URL"
  ],
  "files": [
    {
      "path": "apps/web/src/lib/neon/client.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/neon/branching.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/data/neon/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "neon-postgres",
      "neon",
      "drizzle"
    ],
    "rules": [
      "separate-preview-branches",
      "keep-migrations-committed",
      "validate-database-url"
    ]
  }
}
