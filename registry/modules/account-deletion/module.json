{
  "name": "account-deletion",
  "type": "module",
  "category": "compliance",
  "title": "Account Deletion",
  "description": "Account deletion requests, grace windows, and cleanup checklist.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/account-deletion.ts",
