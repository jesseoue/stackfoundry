{
  "name": "ai-chat",
  "type": "module",
  "category": "ai",
  "title": "AI Chat",
  "description": "AI SDK chat route, model selector, message persistence, and prompt input.",
  "dependencies": [
    "ai",
    "@ai-sdk/react",
    "@ai-sdk/gateway"
  ],
  "devDependencies": [],
  "registryDependencies": [],
  "env": [
    "AI_GATEWAY_API_KEY",
    "AI_GATEWAY_MODEL"
  ],
  "files": [
    {
      "path": "apps/web/src/app/api/ai/chat/route.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/components/ai/chat-box.tsx",
      "type": "registry:component"
    },
    {
      "path": "apps/web/src/lib/ai/prompts.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/ai/models.ts",
      "type": "registry:file"
    }
  ],
  "status": "experimental",
  "maintenance": {
    "skills": [
      "ai-chat",
      "ai-sdk",
      "nextjs"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release"
    ]
  }
}
