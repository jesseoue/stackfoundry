{
  "name": "cloudflare-turnstile",
  "type": "integration",
  "category": "security",
  "title": "Cloudflare Turnstile",
  "description": "Bot protection for signup, contact, waitlist, and abuse-sensitive forms.",
  "dependencies": [],
