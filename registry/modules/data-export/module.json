{
  "name": "data-export",
  "type": "module",
  "category": "compliance",
  "title": "Data Export",
  "description": "User and workspace export requests with status tracking.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/data-export.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/data-export.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/data/export/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "dataExport"
    ],
    "migrationRecommended": true
  },
  "agents": {
    "skills": [
      "data-export"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  },
  "status": "experimental"
}
