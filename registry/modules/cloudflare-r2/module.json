{
  "name": "cloudflare-r2",
  "type": "integration",
  "category": "storage",
  "title": "Cloudflare R2",
  "description": "R2 object storage adapter example for uploads and private object reads.",
  "dependencies": [],
  "devDependencies": [
    "wrangler"
  ],
  "registryDependencies": [
    "file-uploads"
  ],
  "env": [],
  "files": [
    {
      "path": "cloudflare/r2/storage.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/admin/cloudflare/r2/page.tsx",
      "type": "registry:page"
    }
  ],
  "agents": {
    "skills": [
      "cloudflare-r2"
    ],
    "rules": [
      "private-by-default",
      "validate-object-keys",
      "document-bucket-bindings"
    ]
  },
  "status": "experimental"
}
