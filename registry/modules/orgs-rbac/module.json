{
  "name": "orgs-rbac",
  "type": "module",
  "category": "auth",
  "title": "Organizations RBAC",
  "description": "Organization role catalog, permission helpers, and workspace role management surface.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres",
    "tenant-context"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/orgs-rbac.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/stackfoundry/orgs-rbac.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/settings/workspace/rbac/page.tsx",
      "type": "registry:page"
    }
  ],
  "status": "ready",
  "maintenance": {
    "skills": [
      "orgs-rbac",
      "drizzle",
      "nextjs"
    ],
    "rules": [
      "centralize-permission-checks",
      "audit-role-changes",
      "keep-roles-tenant-scoped"
    ]
  }
}
