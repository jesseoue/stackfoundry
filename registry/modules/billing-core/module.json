{
  "name": "billing-core",
  "type": "module",
  "category": "billing",
  "title": "Billing Core",
  "description": "Provider-neutral customer, plan, and subscription primitives.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "drizzle-postgres"
  ],
  "env": [],
  "files": [
    {
      "path": "packages/db/src/schema/billing-core.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/lib/billing-core.ts",
      "type": "registry:file"
    },
    {
      "path": "apps/web/src/app/(console)/billing/core/page.tsx",
      "type": "registry:page"
    }
  ],
  "drizzle": {
    "schemaExports": [
      "billingCore"
    ],
    "migrationRecommended": true
  },
  "status": "ready",
  "maintenance": {
    "skills": [
      "billing-core",
      "nextjs",
      "drizzle"
    ],
    "rules": [
      "document-invariants",
      "verify-before-release",
      "keep-provider-boundary"
    ]
  }
}
